{{#if success_msg.length}}
  <div style="padding: 10px 16px; margin: 10px 0; background: #28a745; color: #fff; font-size: 14px; font-weight: 500; text-align: center;">{{success_msg}}</div>
{{/if}}

{{#if error_msg.length}}
  <div style="padding: 10px 16px; margin: 10px 0; background: #dc3545; color: #fff; font-size: 14px; font-weight: 500; text-align: center;">{{error_msg}}</div>
{{/if}}