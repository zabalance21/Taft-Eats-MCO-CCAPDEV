<!DOCTYPE html>

<html>

    <head>
        <title> Taft Eats | Restaurant Reviews </title>

        <link rel = "stylesheet" type = "text/css" href = "../css/main.css">
    
        <script src="../js/jquery-4.0.0.min.js"></script>
        <script src="../js/data.js"></script>
        <script src="../js/main.js"></script>
    </head>  

    <body>

        <!-- Navigation -->
        {{> navbar}}

        <main class="est_rev">

            <!-- Establishment Name -->
            <section class = "establishment-header">
                <h2>{{restaurant.name}}</h2>
            </section>

            <!-- Overall Rating Section -->
            <section class = "overall-rating">

                <div class = "rating-summary">
                    <h1>{{avgRating}}</h1>
                    <p class = "stars">{{stars}}</p>
                    <p>{{reviewCount}} reviews</p>
                </div>

                <div class = "rating-distribution">
                    <!-- JS will populate these fields from data.js -->
                    <div class = "rating-row">
                        <span></span>
                        <div class = "bar full"></div>
                    </div>
                    <div class = "rating-row">
                        <span></span>
                        <div class = "bar"></div>
                    </div>
                    <div class = "rating-row">
                        <span></span>
                        <div class = "bar"></div>
                    </div>
                    <div class = "rating-row">
                        <span></span>
                        <div class = "bar"></div>
                    </div>
                    <div class = "rating-row">
                        <span></span>
                        <div class = "bar"></div>
                    </div>
                </div>

                {{#if user}}
                <div class="restaurant-vote">
                    <button type="button" class="rest-like-btn{{#if userLiked}} active{{/if}}" data-restaurant-id="{{restaurant.id}}" data-type="like">
                        👍 Like
                    </button>
                    <button type="button" class="rest-dislike-btn{{#if userDisliked}} active{{/if}}" data-restaurant-id="{{restaurant.id}}" data-type="dislike">
                        👎 Dislike
                    </button>
                </div>
                {{/if}}

            </section>

            <!-- Reviews Section -->
            <section class = "reviews-section">

                <div class="revs_header">
                    <h3 class="header_revs"> Reviews </h3>

                    <input type = "text" id = "search-reviews" placeholder = "Search reviews...">

                    <a id = "create-review-btn" href="/review/create?restaurantId={{restaurant.id}}"> Write a Review </a>
                </div>
                
                <!-- Review Card -->
                {{#each reviews}}
                    <div class = "review-card" data-id="{{this.id}}">
                        <div class="review-header">
                            <div class="review-user">
                                <img src="{{this.user.avatar}}" alt="User Avatar" class="avatar">
                                <div>
                                    <strong>{{this.user.fullName}}</strong>
                                    <p>{{this.formattedDate}}{{#if this.edited}}(Edited){{/if}}</p>
                                </div>
                            </div>
                            <div class="review-rating">
                                <span{{this.rating}}</span>
                                <span class="stars">{{this.stars}}</span>
                            </div>
                        </div>
                        
                        <h4 class="main_review_h">{{this.title}}</h4>

                        <p class="main_review_p truncated" data-full-body="{{this.body}}">{{this.body}}</p>

                        {{#if this.media}}
                            <div class="review-media">
                                <img src="/{{this.media}}" alt="Review Media" style="max-width:400px;">
                            </div>
                        {{/if}}

                        {{#if this.ownerResponse}}
                            <div class="owner-response">
                                <strong>Official Owner Response:</strong>
                                <p>{{this.ownerResponse}}</p>
                            </div>
                        {{/if}}

                        <div class="review-footer">

                            {{#if ../currentUser}}
                                <button type="button" class="vote-btn helpful-btn" data-review-id="{{this._id}}" data-type="helpful">
                                    👍 Helpful (<span class="helpful-count">{{this.helpful}}</span>)
                                </button>
                                <button type="button" class="vote-btn unhelpful-btn" data-review-id="{{this._id}}" data-type="unhelpful">
                                    👎 Unhelpful (<span class="unhelpful-count">{{this.unhelpful}}</span>)
                                </button>
                            {{else}}
                                <button type="button" class="vote-btn helpful-btn" disabled aria-disabled="true">
                                    👍 Helpful (<span class="helpful-count">{{this.helpful}}</span>)
                                </button>
                                <button type="button" class="vote-btn unhelpful-btn" disabled aria-disabled="true">
                                    👎 Unhelpful (<span class="unhelpful-count">{{this.unhelpful}}</span>)
                                </button>
                            {{/if}}

                            {{#if this.isReviewOwner}}
                                <a href="/review/edit/{{this._id}}">
                                    <button type="button" class="edit-review-btn">Edit</button>
                                </a>
                                <form action="/review/delete/{{this._id}}" method="post" style="display: inline;">
                                    <input type="hidden" name="restaurantId" value="{{../restaurant.id}}">
                                    <button class="delete-review-btn"
                                        onclick="return confirm('Are you sure you want to delete this review?')">
                                        Delete</button>
                                </form>
                            {{/if}}

                            {{#if ../isOwner}}
                                {{#if this.ownerResponse}}
                                    <!-- Owner already replied: show Edit Reply button -->
                                    <button class="respond-btn" onclick="toggleReplyForm(this)">Edit Reply</button>
                                {{else}}
                                    <!-- Owner has not replied yet: show Write Reply button -->
                                    <button class="respond-btn" onclick="toggleReplyForm(this)">Write Reply</button>
                                {{/if}}
                            {{/if}}

                            <span class="read-full-review-btn" onclick="toggleReview(this)">Read Full Review</span>
                        </div>

                        {{#if ../isOwner}}
                            <!-- Reply form (hidden by default, shown when Write/Edit Reply is clicked) -->
                            <div class="reply-form-container" style="display: none;">
                                <form action="/review/respond{{#if this.ownerResponse}}/edit{{/if}}/{{this._id}}" method="post" class="reply-form">
                                    <label for="ownerResponse"><strong>Your Response:</strong></label>
                                    <textarea name="ownerResponse" rows="4" placeholder="Write your response..." required>{{this.ownerResponse}}</textarea>
                                    <div class="reply-form-actions">
                                        <button type="submit" class="reply-submit-btn">Submit Response</button>
                                        <button type="button" class="reply-cancel-btn" onclick="toggleReplyForm(this)">Cancel</button>
                                    </div>
                                </form>
                            </div>
                        {{/if}}
                    </div>
                {{/each}}
            </section>

        </main>

        <!-- Footer-->
        {{> footer}}

    </body>

</html>
