<!DOCTYPE html>
<html>

<head>
    <title> Taft Eats | View Review </title>

    <link rel = "stylesheet" type = "text/css" media = "all" href = "/css/main.css">

    <script src = "/js/jquery-4.0.0.min.js"></script>
    <script src = "/js/main.js"></script>
</head>

<body>
    <!-- Dynamic Navigation Bar -->
    {{> navbar}}

    <!-- Full Review Section -->
    <main class="centering">
        <section class = "review-full-section">
            
            <h2>{{review.restaurant.name}}</h2>

            <div class="full_rev">
                <div class = "review-header">

                <div class = "review-user">
                    <img src = "{{review.user.avatar}}" alt = "User Avatar" class="avatar">
                    <div>
                        <strong>{{review.user.fullName}}</strong>
                        <p class = "review-date">{{review.formattedDate}}</p>
                    </div>
                </div>

                    <div class = "review-rating">
                        <span>{{review.rating}}</span>
                        <span class = "stars">{{review.stars}}</span>
                    </div>

                </div>

                <div class = "review-body">
                    <p>{{review.body}}</p>
                    {{#if review.media}}
                        <div><img src="/{{review.media}}" alt="Review Media" style="max-width:400px;"></div>
                    {{/if}}
                </div>

                <div class = "review-footer">
                    <!-- CHANGED: Logged-in users can vote; guests see unclickable display-only buttons. -->
                    {{#if user}}
                        <button type="button" class="vote-btn helpful-btn" data-review-id="{{review._id}}" data-type="helpful">
                            👍 Helpful (<span class="helpful-count">{{review.helpful}}</span>)
                        </button>
                        <button type="button" class="vote-btn unhelpful-btn" data-review-id="{{review._id}}" data-type="unhelpful">
                            👎 Unhelpful (<span class="unhelpful-count">{{review.unhelpful}}</span>)
                        </button>
                    {{else}}
                        <button type="button" class="vote-btn helpful-btn" disabled aria-disabled="true">
                            👍 Helpful (<span class="helpful-count">{{review.helpful}}</span>)
                        </button>
                        <button type="button" class="vote-btn unhelpful-btn" disabled aria-disabled="true">
                            👎 Unhelpful (<span class="unhelpful-count">{{review.unhelpful}}</span>)
                        </button>
                    {{/if}}
                </div>
                </div>
        </section>
    </main>

    <!-- Footer -->
    {{> footer}}
</body>
</html>